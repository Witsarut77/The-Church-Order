<Defs>
  <HediffDef>
    <defName>SanguineHemorrhage</defName>
    <label>sanguine hemorrhage</label>
    <description>A specialized biological anticoagulant has entered the bloodstream. The wound refuses to clot, and the victim feels a rhythmic, burning pulse that slows their movements.</description>
    <hediffClass>HediffWithComps</hediffClass>
    <comps>
      <li Class="HediffCompProperties_TendDuration">
        <baseTendDurationHours>12</baseTendDurationHours>
        <severityPerDayTended>-0.5</severityPerDayTended>
      </li>
      <li Class="HediffCompProperties_Immunizable">
        <severityPerDayNotTended>0.2</severityPerDayNotTended>
      </li>
    </comps>
    <stages>
      <li>
        <label>initial</label>
        <becomeVisible>true</becomeVisible>
      </li>
      <li>
        <minSeverity>0.3</minSeverity>
        <label>throbbing</label>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.10</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.6</minSeverity>
        <label>heavy pulse</label>
        <painOffset>0.2</painOffset>
        <capMods>
          <li>
            <capacity>Moving</capacity>
            <offset>-0.25</offset>
          </li>
          <li>
            <capacity>Manipulation</capacity>
            <offset>-0.15</offset>
          </li>
        </capMods>
      </li>
      <li>
        <minSeverity>0.9</minSeverity>
        <label>exsanguination</label>
        <lifeThreatening>true</lifeThreatening>
        <painOffset>0.4</painOffset>
        <capMods>
          <li>
            <capacity>Consciousness</capacity>
            <offset>-0.20</offset>
          </li>
        </capMods>
      </li>
    </stages>
  </HediffDef>
</Defs>